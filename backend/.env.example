DEEPSEEK_API_KEY=your_deepseek_api_key_here
OPENAI_API_KEY=your_openai_api_key_here
DEEPSEEK_MODEL=deepseek-v4-flash
DEEPSEEK_BASE_URL=https://api.deepseek.com
IMAGE_SIZE=1024x1024
IMAGE_CONCURRENCY=6
MAX_DIALOGUE_ROUNDS=8

# Doubao Seedream (default image generation model)
DOUBAO_API_KEY=your_doubao_api_key_here
DOUBAO_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
DOUBAO_MODEL=doubao-seedream-5-0-260128
DOUBAO_IMAGE_SIZE=1024x1024

# Default image provider: "doubao" or "openai"
DEFAULT_IMAGE_PROVIDER=doubao
